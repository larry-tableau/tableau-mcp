# Mode B: HTTP + OAuth + UAT + {OAUTH_USERNAME}
# Usage: copy to tests/.env, then fill in the placeholder values below.
#
# Step 1 — generate keys: npx tsx uat/scripts/generateKeys.ts
# Step 2 — register UAT:  SITE_NAME=<slug> TCM_PAT_SECRET=<secret> npx tsx uat/scripts/registerUat.ts
# Step 3 — fill in the values printed by each script below, then start the server.

TRANSPORT=http
AUTH=uat
SERVER=https://<your-tableau-cloud-pod>.online.tableau.com/
SITE_NAME=<your-site-content-url>

# From TCM API response printed by registerUat.ts:
UAT_TENANT_ID=
UAT_ISSUER=

UAT_USERNAME_CLAIM_NAME=email
UAT_USERNAME_CLAIM={OAUTH_USERNAME}

# Absolute path printed by generateKeys.ts:
UAT_PRIVATE_KEY_PATH=

OAUTH_ISSUER=http://127.0.0.1:3927

# Absolute path printed by generateKeys.ts:
OAUTH_JWE_PRIVATE_KEY_PATH=

DEFAULT_LOG_LEVEL=debug
